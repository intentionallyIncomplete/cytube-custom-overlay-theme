{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "BTFW": "readonly",
    "socket": "readonly",
    "videojs": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["modules/**/*.js"],
      "globals": {
        "CLIENT": "readonly",
        "CHANNEL": "readonly",
        "USEROPTS": "readonly",
        "jQuery": "readonly",
        "Callbacks": "readonly",
        "parseMediaLink": "readonly",
        "makeAlert": "readonly",
        "openGifModal": "readonly"
      },
      "rules": {
        "no-redeclare": ["error", { "builtinGlobals": false }]
      }
    },
    {
      "files": ["test/**/*.js", "scripts/**/*.js", "lib/**/*.js"],
      "env": {
        "node": true,
        "browser": true
      },
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      }
    },
    {
      "files": ["modules/util-constants.js", "modules/util-dom.js", "modules/util-state.js", "modules/util-templates.js", "modules/util-chat-autoscroll.js"],
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      }
    },
    {
      "files": ["modules/user-release-notes.generated.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["**/*.ts"],
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "extends": ["plugin:@typescript-eslint/recommended"],
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      },
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
      }
    }
  ]
}
